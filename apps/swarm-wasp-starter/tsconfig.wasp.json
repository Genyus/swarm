{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ES2022",
    "isolatedModules": true,
    "moduleDetection": "force",

    // linting
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,

    "lib": ["ES2023"]
  },
  "include": ["**/*.wasp.ts", ".wasp/out/types/spec"]
}
